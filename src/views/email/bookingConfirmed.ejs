<div
  style="
    font-family: Arial, sans-serif;
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 10px;
    max-width: 560px;
    margin: auto;
  "
>
  <h2 style="color: #333; text-align: center; margin-bottom: 10px">Gala Tab</h2>

  <p style="font-size: 15px; color: #555; margin-bottom: 10px">
    Hello <%= data.customerName || 'Guest' %>,
  </p>

  <p style="font-size: 15px; color: #555; margin-bottom: 10px">
    Your booking for <strong><%= data.serviceTitle %></strong> has been confirmed!
  </p>

  <!-- Booking Details -->
  <div
    style="
      background: #f4f4f4;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 15px;
    "
  >
    <h3 style="color: #333; margin-top: 0; margin-bottom: 10px; font-size: 16px">
      Booking Details
    </h3>
    <table style="width: 100%; font-size: 14px; color: #555">
      <tr>
        <td style="padding: 4px 0; font-weight: bold">Check-In:</td>
        <td style="padding: 4px 0"><%= data.checkIn %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; font-weight: bold">Check-Out:</td>
        <td style="padding: 4px 0"><%= data.checkOut %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; font-weight: bold">Guests:</td>
        <td style="padding: 4px 0"><%= data.guests %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; font-weight: bold">Total Price:</td>
        <td style="padding: 4px 0">$<%= data.totalPrice %></td>
      </tr>
    </table>
  </div>

  <!-- Service Address (revealed upon confirmation) -->
  <% if (data.serviceAddress) { %>
  <div
    style="
      background: #e6f4ea;
      border: 1px solid #34a853;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 15px;
    "
  >
    <h3 style="color: #34a853; margin-top: 0; margin-bottom: 8px; font-size: 16px">
      Venue Address
    </h3>
    <p style="font-size: 14px; color: #333; margin: 0">
      <%= data.serviceAddress %>
    </p>
    <% if (data.mapLink) { %>
    <p style="margin-top: 10px; margin-bottom: 0">
      <a
        href="<%= data.mapLink %>"
        style="
          color: #007bff;
          text-decoration: none;
          font-size: 14px;
        "
        >View on Google Maps &rarr;</a
      >
    </p>
    <% } %>
  </div>
  <% } %>

  <p style="font-size: 14px; color: #555; margin-bottom: 10px">
    You can view your booking details anytime in your dashboard.
  </p>

  <hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0" />
  <p style="font-size: 12px; color: #aaa">
    &copy; <%= new Date().getFullYear() %> Gala Tab. All rights reserved.
  </p>
</div>
